{
  "atom_version": "0.1.0",
  "atom_id": "A4",
  "atom_name": "State Inventory",
  "primary_mechanism": "MemorySlice",
  "supporting_mechanisms": [
    "TaskSpec"
  ],
  "capability_under_test": "Identify existing, missing, protected, and unknown project state from a fixed snapshot.",
  "non_goals": [
    "Do not evaluate general prose quality.",
    "Do not evaluate broad end-to-end workflow success."
  ],
  "input_contract": {
    "required_inputs": [
      "input.md",
      "task_spec.json",
      "output_contract.json"
    ],
    "fixed_snapshot": true,
    "forbidden_assumptions": [
      "Do not use live web state.",
      "Do not assume files, evidence, or constraints absent from the fixture."
    ]
  },
  "output_contract_id": "out_mechanism_a4_state_inventory_001",
  "pass_criteria": [
    {
      "metric": "state_accuracy",
      "threshold": 1.0,
      "required": true
    },
    {
      "metric": "task_success",
      "threshold": 0.8,
      "required": true
    }
  ],
  "known_failure_modes": [
    "State hallucination"
  ],
  "composition_interface": {
    "input_from_previous": [
      "fixed_snapshot"
    ],
    "output_to_next": [
      "state_inventory"
    ],
    "state_dependencies": [
      "memory_slice"
    ],
    "evidence_dependencies": [],
    "failure_signal": "state-inventory_failed",
    "repair_policy": "stop_and_report"
  }
}
