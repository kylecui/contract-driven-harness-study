    {"id": "g3-urgent", "input": {"depth": "urgent", "rigor": false}, "expected": {"depth": "urgent", "rigor": false}, "description": "Urgent mode, no rigor"},
    {"id": "g4-rigor-on", "input": {"depth": "balanced", "rigor": true}, "expected": {"depth": "balanced", "rigor": true}, "description": "Balanced with rigor explicitly on"},
    {"id": "g5-missing-file", "input": null, "expected": {"depth": "balanced", "rigor": false}, "description": "File does not exist → defaults"}
